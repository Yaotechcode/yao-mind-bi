{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022"
  },
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/server"
  ],
  "include": [
    "src/components/**/*",
    "src/pages/**/*",
    "src/hooks/**/*",
    "src/providers/**/*",
    "src/lib/**/*",
    "src/styles/**/*",
    "src/shared/**/*",
    "src/client/**/*"
  ]
}