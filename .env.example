# =============================================================================
# Yao Mind — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# =============================================================================

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Standard (non-SRV) format — use this if querySrv / DNS SRV resolution fails.
# Find your hostnames in Atlas → Connect → Drivers → copy the three shard hosts.
# Format: mongodb://user:pass@host1:27017,host2:27017,host3:27017/dbname?authSource=admin&replicaSet=replicaSetName
MONGODB_URI=mongodb://your-username:your-password@host1.mongodb.net:27017,host2.mongodb.net:27017,host3.mongodb.net:27017/your-db-name?authSource=admin&replicaSet=your-replica-set-name
MONGODB_DB_NAME=yao-mind-dev
YAO_CREDENTIAL_ENCRYPTION_KEY=  # 32-byte hex string, generate with: openssl rand -hex 32
YAO_API_BASE_URL=https://api.yao.legal
YAO_API_CODE=  # MFA/firm code for Yao API login
