# =============================================================================
# Yao Mind — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# =============================================================================

# --- Supabase ---
# Your Supabase project URL (found in Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — safe to expose to browsers
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER expose to clients; server/functions only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- MongoDB ---
# Full MongoDB Atlas connection string (include username, password, cluster)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# The MongoDB database name to use (e.g. yao-mind-dev, yao-mind-prod)
MONGODB_DB_NAME=yao-mind-dev
