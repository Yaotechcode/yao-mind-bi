import { Handler } from '@netlify/functions';
import { PullOrchestrator } from '../datasource/PullOrchestrator';
import { authenticateRequest } from '../lib/auth-middleware';

export const handler: Handler = async (event) => {
  // 1. Authenticate the request
  const { firmId } = await authenticateRequest(event);

  // 2. Run the pull (long-running — no timeout)
  const orchestrator = new PullOrchestrator(firmId);
  const result = await orchestrator.run();

  // 3. Return result (Background Functions return 202 immediately
  //    but the actual function continues running)
  return {
    statusCode: result.success ? 200 : 500,
    body: JSON.stringify(result)
  };
};

