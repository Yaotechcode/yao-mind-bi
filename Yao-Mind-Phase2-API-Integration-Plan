PullOrchestrator.run() sequence:

1. await requireNoConcurrentPull(firmId)
2. await startPull(firmId)

3. await updatePullStage(firmId, 'Authenticating')
   adapter = new DataSourceAdapter(firmId)
   await adapter.authenticate()

4. await updatePullStage(firmId, 'Fetching lookup tables')
   { attorneys, departments, caseTypes, maps } = await adapter.fetchLookupTables()

5. await updatePullStage(firmId, 'Fetching matters')
   matters = await adapter.fetchMatters()
   await updatePullStage(firmId, 'Fetching matters', { matters: matters.length })

6. Fetch remaining datasets in parallel:
   await updatePullStage(firmId, 'Fetching time entries, invoices, ledgers, tasks, contacts')
   [timeEntries, invoices, rawLedgers, tasks, contacts, invoiceSummary] = await Promise.all([
     adapter.fetchTimeEntries(),
     adapter.fetchInvoices(),
     adapter.fetchLedgers(),
     adapter.fetchTasks(),
     adapter.fetchContacts(),
     adapter.fetchInvoiceSummary()
   ])
   ledgers = adapter.routeLedgers(rawLedgers)

7. await updatePullStage(firmId, 'Normalising')
   normalisedData = normaliseAll(rawData, maps)
   stripSensitiveFromAll(normalisedData)  // belt-and-suspenders

8. await updatePullStage(firmId, 'Enriching')
   wipEnrichment = buildWipEnrichment(normalisedData.timeEntries)
   enrichedInvoices = enrichInvoicesWithDatePaid(normalisedData.invoices, ledgers.invoicePayments)
   enrichedFeeEarners = await mergeAllFeeEarners(normalisedData.attorneys, firmId)
   clientProfiles = buildClientProfiles(normalisedData.contacts, normalisedData.matters, enrichedInvoices)

9. await updatePullStage(firmId, 'Storing enriched data')
   Store enriched entities in MongoDB (enriched_entities collection)

10. await updatePullStage(firmId, 'Calculating KPIs')
    config = await getFirmConfig(firmId)
    kpiResults = await formulaEngine.executeBatch(enrichedData, config)
    ragResults = ragEngine.applyThresholds(kpiResults, config)

11. await updatePullStage(firmId, 'Storing KPIs')
    Store calculated KPIs in MongoDB (calculated_kpis collection)

12. await updatePullStage(firmId, 'Writing snapshots')
    snapshots = buildSnapshotsFromKpiResults(firmId, pulledAt, kpiResults)
    await writeKpiSnapshots(firmId, snapshots)

13. await updatePullStage(firmId, 'Scanning for risks')
    flags = scanForRiskFlags({ firmId, kpiSnapshots: snapshots, config, pulledAt })
    await storeRiskFlags(firmId, flags)

14. await completePull(firmId)
    return { success: true, stats, errors: [], warnings: [] }

